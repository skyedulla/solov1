{
  "name": "solo-backend",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "token": "node scripts/print-supabase-token.cjs",
    "test:e2e": "jest --config jest.e2e.config.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@supabase/supabase-js": "^2.103.3",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "prisma": "^6.3.1",
    "tree-kill": "^1.2.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
