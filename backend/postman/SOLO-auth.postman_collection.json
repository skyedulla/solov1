          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mindmapId\": \"{{mindmapId}}\",\n  \"sourceNodeId\": \"{{nodeId}}\",\n  \"sourceAnchor\": \"right\"\n}"
            },
            "url": "{{baseUrl}}/mindmap-connection",
            "description": "**`mindmapId`** in JSON is **required**. Omit **`targetNodeId`** / **`targetAnchor`** together for an open-ended link. **`sourceAnchor`**: **`top`** | **`right`** | **`left`** | **`bottom`**. **`201`** — Tests script stores **`connectionId`**."
          }
        },
        {
          "name": "Create mindmap-connection with target (POST /mindmap-connection)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data && data.id) {",
                  "    pm.collectionVariables.set('connectionId', data.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mindmapId\": \"{{mindmapId}}\",\n  \"sourceNodeId\": \"{{nodeId}}\",\n  \"sourceAnchor\": \"right\",\n  \"targetNodeId\": \"PASTE_SECOND_NODE_UUID\",\n  \"targetAnchor\": \"left\"\n}"
            },
            "url": "{{baseUrl}}/mindmap-connection",
            "description": "**`targetNodeId`** and **`targetAnchor`** must both be set or both omitted. Replace **`PASTE_SECOND_NODE_UUID`** with another mindmap-node on the same **`mindmapId`** (e.g. from **Search mindmap-nodes** or a second **Sync mindmap-node create**)."
          }
        },
        {
          "name": "Update mindmap-connection PATCH",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mindmapId\": \"{{mindmapId}}\",\n  \"sourceNodeId\": \"{{nodeId}}\",\n  \"targetNodeId\": null,\n  \"sourceAnchor\": \"bottom\",\n  \"targetAnchor\": null\n}"
            },
            "url": "{{baseUrl}}/mindmap-connection/{{connectionId}}",
            "description": "Partial update; **`null`** clears **`targetNodeId`** / **`targetAnchor`**. Include **`mindmapId`** when changing map membership. **`200`**."
          }
        },
        {
          "name": "Update mindmap-connection PUT",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mindmapId\": \"{{mindmapId}}\",\n  \"sourceNodeId\": \"{{nodeId}}\",\n  \"targetNodeId\": null,\n  \"sourceAnchor\": \"bottom\",\n  \"targetAnchor\": null\n}"
            },
            "url": "{{baseUrl}}/mindmap-connection/{{connectionId}}",
            "description": "Same as **PATCH** if **`PATCH`** is blocked."
          }
        },
        {
          "name": "Delete mindmap-connection (DELETE /mindmap-connection/:id)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/mindmap-connection/{{connectionId}}",
            "description": "**`204`** success; **`404`** if id not found."
          }
        }
      ]
    },
