          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mindmaps?idea_id={{ideaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["mindmaps"],
              "query": [
                {
                  "key": "idea_id",
                  "value": "{{ideaId}}",
                  "description": "Required — UUID of the idea whose mind maps to list"
                }
              ]
            },
            "description": "**`GET /mindmaps?idea_id=`** — lists mind maps for the authenticated user and idea (**`200`** array of **`id`**, **`idea_id`**, **`title`**, **`summary`**, timestamps)."
          }
        },
        {
          "name": "Load mindmap document (GET /mindmaps/:id)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mindmaps/{{mindmapId}}?idea_id={{ideaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["mindmaps", "{{mindmapId}}"],
              "query": [
                {
                  "key": "idea_id",
                  "value": "{{ideaId}}",
                  "description": "Required — must match the mind map row's idea"
                }
              ]
            },
            "description": "Full document: **`title`**, **`nodes`** (**mindmap-nodes**), **`connections`** (**mindmap-connections**), **`last_transform`**. **`mindmapId`** in path; **`idea_id`** query required (**`404`** if mismatch or not found)."
          }
        },
        {
          "name": "Generate mindmap summary (POST /mindmaps/:id/generate-summary)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mindmaps/{{mindmapId}}/generate-summary?idea_id={{ideaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["mindmaps", "{{mindmapId}}", "generate-summary"],
              "query": [
                {
                  "key": "idea_id",
                  "value": "{{ideaId}}",
                  "description": "Required — must match the mind map row's idea"
                }
              ]
            },
            "description": "**`OPENAI_API_KEY`** required on server. Loads **mindmap-nodes** + **mindmap-connections** + **`mindmapSummarizationPrompt`** → **`completeChat`**; persists **`mindmaps.summary`**. **`200`** **`{ summary }`**; **`404`** not found; **`503`** LLM / missing key."
          }
        },
        {
          "name": "Delete mindmap (DELETE /mindmaps/:id)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mindmaps/{{mindmapId}}?idea_id={{ideaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["mindmaps", "{{mindmapId}}"],
              "query": [
                {
                  "key": "idea_id",
                  "value": "{{ideaId}}",
                  "description": "Required — must match the mind map's idea"
                }
              ]
            },
            "description": "**`204`** on success; **`404`** if not found / **`idea_id`** mismatch."
          }
        }
      ]
    },
    {
      "name": "Mindmap-nodes",
      "item": [
        {
          "name": "Search mindmap-nodes (searchMindmapNodes)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mindmap-node?mindmap_id={{mindmapId}}&q=",
              "host": ["{{baseUrl}}"],
              "path": ["mindmap-node"],
              "query": [
                {
                  "key": "mindmap_id",
                  "value": "{{mindmapId}}",
                  "description": "Required query param — UUID of the mind map (**{{mindmapId}}**)"
                },
                {
                  "key": "q",
                  "value": "",
                  "description": "Optional; empty = first 5 mindmap-nodes by text A–Z. Non-empty = substring match, up to 5, ordered by suffix after first match"
                }
              ]
            },
            "description": "**`GET /mindmap-node?mindmap_id=`** — **`mindmap_id`** is **required** (use **`{{mindmapId}}`** after **Create mindmap**). Maps to **`MindmapNodeController.searchMindmapNodes`** — at most **5** mindmap-nodes."
          }
        },
        {
          "name": "Sync mindmap-node create (syncNodeToServer, isNew=true)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data && data.id) {",
                  "    pm.collectionVariables.set('nodeId', data.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mindmapId\": \"{{mindmapId}}\",\n  \"position\": { \"x\": 0, \"y\": 0 },\n  \"text\": \"New node label\",\n  \"dimensions\": { \"height\": 40, \"width\": 120 }\n}"
            },
            "url": "{{baseUrl}}/mindmap-node",
            "description": "**`mindmapId`** in JSON is **required** (same UUID as **`mindmap_id`** on **GET**). Maps to **`syncNodeToServer`** **`POST`**. Set **`mindmapId`**; **`201`** saves **`nodeId`**."
          }
        },
        {
          "name": "Sync mindmap-node update (syncNodeToServer, isNew=false) PATCH",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mindmapId\": \"{{mindmapId}}\",\n  \"parentNodeId\": null,\n  \"position\": { \"x\": 10, \"y\": 20 },\n  \"text\": \"Updated node label\",\n  \"dimensions\": { \"height\": 48, \"width\": 140 }\n}"
            },
            "url": "{{baseUrl}}/mindmap-node/{{nodeId}}",
            "description": "Keep **`mindmapId`** (required) aligned with the mindmap-node’s map. Full snapshot **`PATCH`** (**`200`**)."
          }
        },
        {
          "name": "Sync mindmap-node update PUT",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mindmapId\": \"{{mindmapId}}\",\n  \"parentNodeId\": null,\n  \"position\": { \"x\": 10, \"y\": 20 },\n  \"text\": \"Updated node label\",\n  \"dimensions\": { \"height\": 48, \"width\": 140 }\n}"
            },
            "url": "{{baseUrl}}/mindmap-node/{{nodeId}}",
            "description": "Same as **PATCH**; includes required **`mindmapId`** in body."
          }
        },
        {
          "name": "Delete mindmap-node (deleteNode)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/mindmap-node/{{nodeId}}",
            "description": "Maps to **`MindmapNodeController.deleteMindmapNode`** — **`204`**. Path id only; mind map was established at create time."
          }
        }
      ]
    },
    {
      "name": "Mindmap-connections",
      "item": [
        {
          "name": "List mindmap-connections (GET /mindmap-connection)",
          "request": {
            "method": "GET",
